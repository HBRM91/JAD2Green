# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Document Intelligence (opt-in for messy scans) ───────
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# ── Anthropic (Haiku — messy multilingual scans only) ────
ANTHROPIC_API_KEY=

# ── Google Drive (opt-in export, default OFF) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Per-tenant refresh tokens are stored encrypted in the DB, not here.

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SECRET_KEY=<random-64-byte-hex>

# ── Tenant region (MA | EU) ──────────────────────────────
DEFAULT_TENANT_REGION=MA
