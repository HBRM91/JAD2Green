# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# JWT verify key (Supabase Dashboard → Settings → API → JWT Secret)
# Must be ≥32 chars; config.py refuses to start with a known-weak or short value in ENVIRONMENT=production.
SUPABASE_JWT_SECRET=<32+ char secret from Supabase dashboard>

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Document Intelligence (opt-in for messy scans) ───────
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# ── LLM / OCR Provider ───────────────────────────────────
# TODOLIST Phase 1 — fully-Chinese provider stack. Chinese primary
# (best cost / quality for FR/AR MA tenants); Gemini 2.5 Flash Lite
# kept as a cheap last-resort safety net. No Anthropic.
#
# All three (EXTRACTION_MODEL, NARRATIVE_MODEL, OCR_ENGINE) default to
# Chinese managed APIs. Override only if you know why.

# OpenRouter — single key covers Qwen3-Plus, DeepSeek V3, GLM-4-Plus
# (openrouter.ai/keys)
OPENROUTER_API_KEY=

# Aliyun DashScope — PaddleOCR-VL-1.5 for messy multilingual scans
# (dashscope.console.aliyun.com)
DASHSCOPE_API_KEY=

# Google Gemini 2.5 Flash Lite — last-resort cost safety net
# (aistudio.google.com). Optional: omit to disable from cascade.
GEMINI_API_KEY=

# Extraction (raw OCR text → structured activity facts)
# Options: qwen/qwen3-plus | zhipu/glm-4-plus
EXTRACTION_MODEL=qwen/qwen3-plus

# Narrative (snapshot aggregates → French report)
# Options: deepseek/deepseek-chat-v3 | qwen/qwen3-plus | zhipu/glm-4-plus | gemini-2.5-flash-lite
NARRATIVE_MODEL=deepseek/deepseek-chat-v3

# OCR engine for messy scans
OCR_ENGINE=paddleocr_vl_15

# ── Google Drive (opt-in export, default OFF) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Per-tenant refresh tokens are stored encrypted in the DB, not here.

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8000
SECRET_KEY=<random-64-byte-hex>

# ── Security ─────────────────────────────────────────────
ENVIRONMENT=production                        # triggers secret validation at startup
ALLOWED_ORIGINS=https://app.yourdomain.com    # comma-separated frontend origins for CORS
TOKEN_ENCRYPT_KEY=<random-64-byte-hex>        # key for pgp_sym_encrypt (Google tokens at rest)

# ── Tenant region (MA | EU) ──────────────────────────────
DEFAULT_TENANT_REGION=MA
