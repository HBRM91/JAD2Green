# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Document Intelligence (opt-in for messy scans) ───────
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# ── LLM Provider ─────────────────────────────────────────
# Select primary provider for narrative generation.
# Options: gemini-2.5-flash-lite | gemini-3.1-flash-lite | qwen3.7-plus | deepseek-v4-pro | anthropic
# Default: gemini-2.5-flash-lite (cheapest, reliable French)
# On failure the system automatically tries the fallback chain.
LLM_PROVIDER=gemini-2.5-flash-lite

# Google Gemini — primary (get key at aistudio.google.com)
GEMINI_API_KEY=

# OpenRouter — Qwen3.7-Plus + DeepSeek V4 Pro fallbacks (openrouter.ai)
# Both Qwen and DeepSeek route through this single key.
OPENROUTER_API_KEY=

# Anthropic — legacy fallback only (console.anthropic.com)
ANTHROPIC_API_KEY=

# ── Google Drive (opt-in export, default OFF) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Per-tenant refresh tokens are stored encrypted in the DB, not here.

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8000
SECRET_KEY=<random-64-byte-hex>

# ── Security ─────────────────────────────────────────────
ENVIRONMENT=production                        # triggers secret validation at startup
ALLOWED_ORIGINS=https://app.yourdomain.com    # comma-separated frontend origins for CORS
TOKEN_ENCRYPT_KEY=<random-64-byte-hex>        # key for pgp_sym_encrypt (Google tokens at rest)

# ── Tenant region (MA | EU) ──────────────────────────────
DEFAULT_TENANT_REGION=MA
